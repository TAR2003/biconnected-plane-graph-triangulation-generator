\@writefile{toc}{\contentsline {subsection}{\numberline {1.3}The Multi-Edge Problem in Biconnected Graphs}{2}{subsection.1.3}\protected@file@percent }
\newlabel{subsec:multiedge}{{1.3}{2}{The Multi-Edge Problem in Biconnected Graphs}{subsection.1.3}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces Comparison of graph classes. \textbf  {Left:} Triconnected graphs (addressed by Parvez et al. [8]) have no separation pairs, so faces share only boundary edges. \textbf  {Right:} Biconnected graphs (this work) may contain separation pairs (highlighted in red), allowing faces to share internal structure and creating multi-edge conflicts. Our algorithm extends the framework to this more general class through safe root selection and global chord tracking.}}{3}{figure.caption.1}\protected@file@percent }
\providecommand*\caption@xref[2]{\@setref\relax\@undefined{#1}}
\newlabel{fig:graph_comparison}{{1}{3}{Comparison of graph classes. \textbf {Left:} Triconnected graphs (addressed by Parvez et al. [8]) have no separation pairs, so faces share only boundary edges. \textbf {Right:} Biconnected graphs (this work) may contain separation pairs (highlighted in red), allowing faces to share internal structure and creating multi-edge conflicts. Our algorithm extends the framework to this more general class through safe root selection and global chord tracking}{figure.caption.1}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {1.4}Our Contribution}{3}{subsection.1.4}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces The multi-edge problem in biconnected graphs. \textbf  {Left:} In triconnected graphs, any two faces share only boundary edges, enabling independent triangulation. \textbf  {Right:} In biconnected graphs with separation pairs, faces can share internal structure. Naive independent triangulation creates multi-edges (parallel edges between the same vertex pair), violating the simple graph property.}}{4}{figure.caption.2}\protected@file@percent }
\newlabel{fig:multiedge_problem}{{2}{4}{The multi-edge problem in biconnected graphs. \textbf {Left:} In triconnected graphs, any two faces share only boundary edges, enabling independent triangulation. \textbf {Right:} In biconnected graphs with separation pairs, faces can share internal structure. Naive independent triangulation creates multi-edges (parallel edges between the same vertex pair), violating the simple graph property}{figure.caption.2}{}}
