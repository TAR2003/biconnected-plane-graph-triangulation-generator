\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Illustration of Theorem~\ref {thm:safe_root_exists}: A hexagonal face with two existing chords $(v_2, v_5)$ and $(v_3, v_6)$ from previously processed faces (shown in red dashed lines). Viewing this as an outerplanar graph, vertices $v_1$ and $v_4$ have degree 2 on the outer cycle (blue boundary) with no incident internal edges. By the classical theorem, at least two such vertices exist, guaranteeing safe roots for algorithm initialization.}}{26}{figure.caption.7}\protected@file@percent }
\newlabel{fig:outerplanar_safe_roots}{{3}{26}{Illustration of Theorem~\ref {thm:safe_root_exists}: A hexagonal face with two existing chords $(v_2, v_5)$ and $(v_3, v_6)$ from previously processed faces (shown in red dashed lines). Viewing this as an outerplanar graph, vertices $v_1$ and $v_4$ have degree 2 on the outer cycle (blue boundary) with no incident internal edges. By the classical theorem, at least two such vertices exist, guaranteeing safe roots for algorithm initialization}{figure.caption.7}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Illustration of Lemma~\ref {lem:blocking_chord_persists}: A hexagonal face with triangulation $T$ containing blocking chord $(v_2, v_5)$ (red dashed). The root is $v_1$ (blue circle). Chords from the root are shown in blue, and other chords in green. The blocking chord forms triangles with vertices $v_p = v_1$ (root) and $v_q = v_3$, preventing it from being the generating chord by Case 3 of the proof.}}{29}{figure.caption.8}\protected@file@percent }
\newlabel{fig:blocking_chord_example}{{4}{29}{Illustration of Lemma~\ref {lem:blocking_chord_persists}: A hexagonal face with triangulation $T$ containing blocking chord $(v_2, v_5)$ (red dashed). The root is $v_1$ (blue circle). Chords from the root are shown in blue, and other chords in green. The blocking chord forms triangles with vertices $v_p = v_1$ (root) and $v_q = v_3$, preventing it from being the generating chord by Case 3 of the proof}{figure.caption.8}{}}
\newlabel{thm:completeness}{{3}{29}{Completeness}{theorem.3}{}}
\newlabel{fig:blocking_chord_cases}{{5a}{30}{Three exhaustive cases for blocking chord $(a,b)$. In all cases, the blocking chord cannot be flipped according to algorithm rules, ensuring all descendants remain invalid}{figure.caption.9}{}}
\newlabel{sub@fig:blocking_chord_cases}{{a}{30}{Three exhaustive cases for blocking chord $(a,b)$. In all cases, the blocking chord cannot be flipped according to algorithm rules, ensuring all descendants remain invalid}{figure.caption.9}{}}
